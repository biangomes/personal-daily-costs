<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CostsActivity">

    <TextView
        android:id="@+id/textViewDataEHorario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:text="Data e horário"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/editTextDataEHorario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ems="10"
        android:inputType="date"
        app:layout_constraintTop_toBottomOf="@+id/textViewDataEHorario"
        tools:layout_editor_absoluteX="16dp" />

    <TextView
        android:id="@+id/textViewNomeEstabelecimento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Nome do estabelecimento"
        app:layout_constraintTop_toBottomOf="@+id/editTextDataEHorario"
        tools:layout_editor_absoluteX="17dp" />

    <EditText
        android:id="@+id/editTextMultiLineNomeEstabelecimento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ems="10"
        android:gravity="start|top"
        android:inputType="textMultiLine"
        app:layout_constraintTop_toBottomOf="@+id/textViewNomeEstabelecimento"
        tools:layout_editor_absoluteX="16dp" />

    <TextView
        android:id="@+id/textViewValor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Valor da compra"
        app:layout_constraintTop_toBottomOf="@+id/editTextMultiLineNomeEstabelecimento"
        tools:layout_editor_absoluteX="16dp" />

    <EditText
        android:id="@+id/editTextNumberDecimalValorCompra"
        android:layout_width="68dp"
        android:layout_height="43dp"
        android:layout_marginStart="36dp"
        android:layout_marginTop="4dp"
        android:ems="10"
        android:inputType="numberDecimal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewValor" />

    <TextView
        android:id="@+id/textViewCifrao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        android:text="R$"
        app:layout_constraintEnd_toStartOf="@+id/editTextNumberDecimalValorCompra"
        app:layout_constraintHorizontal_bias="0.555"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="243dp" />

    <TextView
        android:id="@+id/textViewDebitoCredito"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/editTextNumberDecimalValorCompra"
        tools:layout_editor_absoluteX="19dp" />

    <TextView
        android:id="@+id/textViewAVista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="À vista"
        tools:layout_editor_absoluteX="15dp"
        tools:layout_editor_absoluteY="301dp" />

</androidx.constraintlayout.widget.ConstraintLayout>